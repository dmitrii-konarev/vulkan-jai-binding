    TASK_NV                 :: TASK_EXT;
    MESH_NV                 :: MESH_EXT;
    TASK_EXT                :: 1 << 6;
    MESH_EXT                :: 1 << 7;
    SUBPASS_SHADING_HUAWEI  :: 1 << 14;
