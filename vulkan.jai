}

VkPipelineBinaryInfoKHR :: struct {
    sType: VkStructureType = .PIPELINE_BINARY_INFO_KHR;
    pNext: *void;
    binaryCount: u32;
    pPipelineBinaries: *VkPipelineBinaryKHR;
}

