    TOP_OF_PIPE                          :: 1 << 0; /* Before subsequent commands are processed */
    DRAW_INDIRECT                        :: 1 << 1; /* Draw/DispatchIndirect command fetch */
    VERTEX_INPUT                         :: 1 << 2; /* Vertex/index fetch */
    VERTEX_SHADER                        :: 1 << 3; /* Vertex shading */
